interface IUsable
{
    void UseItem();
}

class Weapon : IUsable
{
    public string weaponType = "Dagger";
    public void UseItem()
    {
        Debug.Log("Slashed with " + weaponType);
    }
}

class Potion : IUsable
{
    public string potionType = "Health";
    public void UseItem()
    {
        Debug.Log("Drank a " + potionType + " potion");
    }
}